function login() {
    loggedIn = true;
    mostrarFeedback("Login simulat ✅");
    document.getElementById("btnOn").disabled = false;
    document.getElementById("btnOff").disabled = false;
}


// LIGAR LED
function ligar() {

    if(!loggedIn){
        mostrarFeedback("Faz login primer 🔒");
        return;
    }

    mostrarLoading();

    fetch("/api/actuator", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ state: true })
    })
    .then(() => {
        mostrarFeedback("LED encès ✅");
        atualizar();
    });
}


// DESLLIGAR LED
function desligar() {

    if(!loggedIn){
        mostrarFeedback("Faz login primer 🔒");
        return;
    }

    mostrarLoading();

    fetch("/api/actuator", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ state: false })
    })
    .then(() => {
        mostrarFeedback("LED apagat ❌");
        atualizar();
    });
}


// ACTUALITZAR DADES
function atualizar() {

    // ACTUATOR = LED
    fetch("/api/actuator")
    .then(res => res.json())
    .then(data => {

        let estado = document.getElementById("estado");

        estado.innerText = "Estat LED: " + (data.state ? "on" : "off");

        if(data.state === true){
            estado.style.color = "green";
        } else {
            estado.style.color = "red";
        }
    })
    .catch(() => {
        document.getElementById("estado").innerText = "Error al servidor";
    });

    // SENSOR = POTENCIÒMETRE
    fetch("/api/sensor")
    .then(res => res.json())
    .then(data => {
        document.getElementById("sensor").innerText =
            "Sensor: " + data.value;
    })
    .catch(() => {
        document.getElementById("sensor").innerText =
            "Sensor: error";
    });
}


// LOADING
function mostrarLoading(){
    let estado = document.getElementById("estado");
    estado.innerText = "Carregant...";
    estado.style.color = "black";
}


// FEEDBACK
function mostrarFeedback(msg){
    let f = document.getElementById("feedback");

    f.innerText = msg;
    f.style.opacity = "1";

    setTimeout(() => {
        f.style.opacity = "0";
    }, 2000);
}


// ACTIVAR BOTONS DES DEL PRINCIPI
document.getElementById("btnOn").disabled = false;
document.getElementById("btnOff").disabled = false;


// AUTO UPDATE
atualizar();
setInterval(atualizar, 2000);
